# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgres://postgres:postgres@localhost:5432/devin_telegram_bot

# Devin API Configuration
# For legacy v1 keys (apk_* / apk_user_*), only DEVIN_API_KEY is required.
# For service-user v3 keys (cog_*), DEVIN_ORG_ID is also required.
DEVIN_API_KEY=apk_your_devin_api_key_here
# DEVIN_ORG_ID=org_your_devin_org_id_here

# Bot Name (optional)
# BOT_NAME=Devin

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
